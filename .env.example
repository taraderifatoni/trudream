# ── AI ──────────────────────────────────────────────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── Meta / Instagram (optional — only needed for direct publishing) ──
META_ACCESS_TOKEN=
META_APP_ID=
META_APP_SECRET=
INSTAGRAM_ACCOUNT_ID=
FACEBOOK_PAGE_ID=
INSTAGRAM_HANDLE=@aiera.id

# ── Supabase Storage (for public file URLs & persistent history) ──
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=media
SUPABASE_HISTORY_TABLE=history

# ── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.vercel.app
TMP_DIR=/tmp
DATA_DIR=/app/data
